# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Live place search provider
KAKAO_REST_API_KEY=

# Live public transit provider
ODSAY_API_KEY=

# Kakao Auth (social login)
